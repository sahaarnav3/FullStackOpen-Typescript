{
    "compilerOptions": {
        "noImplicitAny": true,
        "noEmit": true,
        "types": [
            "node"
        ],
        "allowImportingTsExtensions": true,
        "target": "esnext",
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noImplicitReturns": true,
        "noFallthroughCasesInSwitch": true,
        "module": "nodenext",
        "esModuleInterop": true,
    }
}